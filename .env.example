# ── Nowcerts API ──────────────────────────────────────────────
NOWCERTS_API_BASE_URL=https://api.nowcerts.com/api
NOWCERTS_USERNAME=your_nowcerts_username
NOWCERTS_PASSWORD=your_nowcerts_password

# ── Supabase (producción) ──────────────────────────────────────
SUPABASE_URL=https://eovqdeaocpccpwwqrbyb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Organización destino en Supabase ──────────────────────────
# UUID de la org a la que pertenecen todos los registros migrados
TARGET_ORG_ID=your_org_uuid

# ── Configuración general ──────────────────────────────────────
# Número de registros por página al consultar Nowcerts
PAGE_SIZE=500
# Segundos de espera entre páginas (para no saturar la API)
REQUEST_DELAY=0.3
# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
